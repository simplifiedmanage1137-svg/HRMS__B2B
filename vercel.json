{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend",
      "entrypoint": "server.js"
    }
  },
  "crons": [
    {
      "path": "/api/cron/missing-clockout",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/daily-absent",
      "schedule": "29 18 * * *"
    },
    {
      "path": "/api/cron/weekly-cleanup",
      "schedule": "30 20 * * 6"
    },
    {
      "path": "/api/cron/monthly-accrual",
      "schedule": "30 19 1 * *"
    }
  ]
}