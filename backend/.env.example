# Copy this file to .env and fill in your values.
# Never commit .env to git.

NODE_ENV=development
PORT=5000

# Comma-separated list of extra allowed CORS origins (beyond the built-in list in server.js)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT — generate a strong random secret (e.g. openssl rand -base64 64)
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d


# Supabase — copy from your Supabase project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Resend — transactional email (https://resend.com)
# NEVER hardcode this key — env var only
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=HRMS <noreply@b2bindemand.agency>
FRONTEND_URL=https://hrms.b2bindemand.agency

# Cron auth — Vercel Cron sends "Authorization: Bearer <CRON_SECRET>" automatically when this
# is set as a project env var. Required so /api/cron/* routes can't be triggered by anyone else.
# Generate with: openssl rand -base64 32
CRON_SECRET=REPLACE_WITH_STRONG_SECRET
